rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Allow anyone to read messages, but only allow creating new messages
    // (no editing or deleting other people's messages).
    match /messages/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.sender is string
                    && request.resource.data.sender.size() > 0
                    && request.resource.data.sender.size() <= 24;
      allow update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
