rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Messages: authenticated users can read and create
    match /messages/{messageId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.text is string
                    && request.resource.data.text.size() > 0
                    && request.resource.data.text.size() <= 500
                    && request.resource.data.sender is string
                    && request.resource.data.sender.size() > 0
                    && request.resource.data.uid == request.auth.uid;

      // Allow authenticated users to update only the reactions field
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);

      // Only the message owner can delete their own message
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.uid;
    }

    // Typing indicators: each user can read all, write only their own doc
    match /typing/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
