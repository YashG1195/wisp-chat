rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Messages: authenticated users can read and create
    match /messages/{messageId} {
      allow read: if request.auth != null;

      // Valid text message OR valid image message (text can be empty)
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.sender is string
                    && request.resource.data.sender.size() > 0
                    && (
                      // Text message: non-empty text, no imageUrl required
                      (
                        request.resource.data.text is string
                        && request.resource.data.text.size() > 0
                        && request.resource.data.text.size() <= 500
                        && !('imageUrl' in request.resource.data)
                      )
                      ||
                      // Image message: imageUrl must be present, text can be empty string
                      (
                        'imageUrl' in request.resource.data
                        && request.resource.data.imageUrl is string
                        && request.resource.data.imageUrl.size() > 0
                        && request.resource.data.text is string
                        && request.resource.data.text.size() <= 500
                      )
                    );

      // Allow two kinds of update:
      // 1. Any authenticated user can update only the reactions field
      // 2. The message owner can edit text (text, edited, editedAt fields only)
      allow update: if request.auth != null
                    && (
                      // Reactions update — any authenticated user
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
                      ||
                      // Text edit — owner only
                      (
                        request.auth.uid == resource.data.uid
                        && request.resource.data.text is string
                        && request.resource.data.text.size() > 0
                        && request.resource.data.text.size() <= 500
                        && request.resource.data.edited == true
                        && request.resource.data.diff(resource.data)
                              .affectedKeys().hasOnly(['text', 'edited', 'editedAt'])
                      )
                    );

      // Only the message owner can delete their own message
      allow delete: if request.auth != null
                    && request.auth.uid == resource.data.uid;
    }

    // Typing indicators: each user can read all, write only their own doc
    match /typing/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Users collection: for user profiles
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'bio', 'photoURL', 'updatedAt']);
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
